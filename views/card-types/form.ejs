<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Card Type Form</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #daeaf5;
            min-height: 100vh;
            padding: 40px 20px;
            color: #1a3a5c;
        }

        h1 {
            font-size: 1.5rem;
            margin-bottom: 28px;
            letter-spacing: 0.04em;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 16px;
            max-width: 400px;
        }

        label {
            font-size: 0.85rem;
            opacity: 0.7;
            margin-bottom: 4px;
            display: block;
        }

        input[type="text"],
        textarea {
            width: 100%;
            background: rgba(255,255,255,0.8);
            border: 1px solid rgba(26, 58, 92, 0.2);
            border-radius: 5px;
            color: #1a3a5c;
            padding: 10px 12px;
            font-size: 0.95rem;
            font-family: inherit;
            outline: none;
            transition: border-color 0.2s;
        }

        input[type="text"]:focus,
        textarea:focus {
            border-color: rgba(26, 58, 92, 0.6);
        }

        textarea {
            resize: vertical;
            min-height: 100px;
        }

        input[type="submit"] {
            align-self: flex-start;
            background: rgba(26, 58, 92, 0.1);
            border: 1px solid rgba(26, 58, 92, 0.3);
            color: #1a3a5c;
            padding: 10px 24px;
            border-radius: 5px;
            cursor: pointer;
            font-size: 0.9rem;
            font-family: inherit;
            transition: background 0.2s, border-color 0.2s;
        }

        input[type="submit"]:hover {
            background: rgba(26, 58, 92, 0.18);
            border-color: rgba(26, 58, 92, 0.6);
        }

        a {
            color: #1a3a5c;
            text-decoration: none;
            font-size: 0.85rem;
            opacity: 0.55;
            transition: opacity 0.2s;
        }

        a:hover {
            opacity: 1;
        }
    </style>
</head>
<body>
    <a href="/card-types">← Back to card types</a>
    <div style="margin-top: 28px;">
        <h1><%= typeof cardType !== 'undefined' ? 'Edit Card Type' : 'New Card Type' %></h1>
        <form action="<%= typeof cardType !== 'undefined' ? '/card-types/' + cardType.id + '/edit' : '/card-types' %>" method="POST">
            <div>
                <label for="name">Name</label>
                <input type="text" id="name" name="name" value="<%= typeof cardType !== 'undefined' ? cardType.name : '' %>">
            </div>
            <div>
                <label for="description">Description</label>
                <textarea id="description" name="description"><%= typeof cardType !== 'undefined' ? cardType.description : '' %></textarea>
            </div>
            <input type="submit" value="<%= typeof cardType !== 'undefined' ? 'Update' : 'Add' %>">
        </form>
    </div>
</body>
</html>
