<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Card Types</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #1a1a2e;
            min-height: 100vh;
            padding: 40px 20px;
            color: #f5e6c8;
        }

        h1 {
            font-size: 1.8rem;
            letter-spacing: 0.05em;
            margin-bottom: 28px;
            text-shadow: 0 2px 8px rgba(0,0,0,0.4);
        }

        .card-type-item {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(245, 230, 200, 0.15);
            border-radius: 6px;
            padding: 14px 20px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        .card-type-item strong {
            font-size: 0.95rem;
        }

        .actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        button {
            background: transparent;
            color: #e06c6c;
            border: 1px solid rgba(224, 108, 108, 0.4);
            padding: 6px 14px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.85rem;
            transition: background 0.2s, border-color 0.2s;
        }

        button:hover {
            background: rgba(224, 108, 108, 0.15);
            border-color: #e06c6c;
        }

        a {
            color: #f5e6c8;
            text-decoration: none;
            font-size: 0.85rem;
            opacity: 0.7;
            transition: opacity 0.2s;
        }

        a:hover {
            opacity: 1;
        }

        .add-link {
            display: inline-block;
            margin-top: 20px;
            opacity: 0.6;
        }

        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        nav {
            display: flex;
            gap: 8px;
            margin-bottom: 28px;
        }

        nav a {
            padding: 7px 16px;
            border: 1px solid rgba(245, 230, 200, 0.2);
            border-radius: 5px;
            font-size: 0.82rem;
            opacity: 0.55;
            background: rgba(255,255,255,0.04);
        }

        nav a:hover {
            opacity: 1;
            background: rgba(245, 230, 200, 0.1);
            border-color: rgba(245, 230, 200, 0.45);
        }

        nav a.active {
            opacity: 1;
            border-color: rgba(245, 230, 200, 0.5);
            background: rgba(245, 230, 200, 0.08);
        }
    </style>
</head>
<body>
    <a href="/" class="back-link">← Home</a>
    <nav>
        <a href="/arcs">Arcs</a>
        <a href="/cards">Cards</a>
        <a href="/card-types" class="active">Card Types</a>
    </nav>
    <h1>Card Types</h1>
    <div>
        <% cardTypes.forEach(cardType => { %>
            <div class="card-type-item">
                <strong><%= cardType.name %></strong>
                <div class="actions">
                    <a href="/card-types/<%= cardType.id %>/edit">Edit</a>
                    <form action="/card-types/<%= cardType.id %>/delete" method="POST" style="display:inline;">
                        <button type="submit">Delete</button>
                    </form>
                </div>
            </div>
        <% }) %>

        <a href="/card-types/new" class="add-link">+ Add new card type</a>
    </div>
</body>
</html>
