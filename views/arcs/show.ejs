<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= arc.name %></title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #daeaf5;
            min-height: 100vh;
            padding: 40px 20px;
            color: #1a3a5c;
        }

        h1 {
            font-size: 1.8rem;
            letter-spacing: 0.05em;
            margin-bottom: 12px;
            text-shadow: 0 2px 8px rgba(0,0,0,0.4);
        }

        p {
            color: rgba(26, 58, 92, 0.7);
            font-size: 0.95rem;
            line-height: 1.6;
            margin-bottom: 24px;
        }

        a {
            color: #1a3a5c;
            text-decoration: none;
            font-size: 0.85rem;
            opacity: 0.55;
            transition: opacity 0.2s;
        }

        a:hover {
            opacity: 1;
        }
    </style>
</head>
<body>
    <a href="/arcs">← Back to arcs</a>
    <div style="margin-top: 24px;">
        <h1><%= arc.name %></h1>
        <p><%= arc.description %></p>
    </div>
</body>
</html>
