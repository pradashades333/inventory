<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Arc Form</title>
</head>
<body>
    <div>
        <form action="<%= typeof arc !== 'undefined' ? '/arcs/' + arc.id + '/edit' : '/arcs' %>" method="POST">
            <label for="name">Arc name:</label>
            <input type="text" id="name" name="name" value="<%= typeof arc !== 'undefined' ? arc.name : '' %>">
            
            <label for="description">Arc Description:</label>
            <textarea id="description" name="description"><%= typeof arc !== 'undefined' ? arc.description : '' %></textarea>
            
            <input type="submit" value="<%= typeof arc !== 'undefined' ? 'Update Arc' : 'Add Arc' %>">
        </form>


        
    </div>
</body>
</html>