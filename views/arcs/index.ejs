<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Arcs</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f0f0f0;
            padding: 20px;
        }

        h1 {
            color: #333;
        }

        .arc-card {
            background-color: white;
            border: 1px solid #ccc;
            padding: 15px;
            margin-bottom: 15px;
            border-radius: 5px;
        }

        .arc-card p {
            margin: 5px 0;
        }

        button {
            background-color: red;
            color: white;
            border: none;
            padding: 5px 10px;
            cursor: pointer;
        }

        a {
            color: blue;
            margin-left: 10px;
        }

        .add-link {
            display: block;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <h1>One Piece Arcs</h1>
    <div>
        <% arcs.forEach(arc => { %>
            <div class="arc-card">
                <p><strong><%= arc.name %></strong></p>
                <p><%= arc.description %></p>
                <form action="/arcs/<%= arc.id %>/delete" method="POST" style="display:inline;">
                    <button type="submit">Delete</button>
                </form>
                <a href="/arcs/<%= arc.id %>/edit">Edit</a>
            </div>
        <% }) %>

        <a href="/arcs/new" class="add-link">+ Add new arc</a>
    </div>
</body>
</html>