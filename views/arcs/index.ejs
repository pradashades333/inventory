<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Arcs</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #daeaf5;
            min-height: 100vh;
            padding: 40px 20px;
            color: #1a3a5c;
        }

        h1 {
            font-size: 1.8rem;
            letter-spacing: 0.05em;
            margin-bottom: 28px;
            text-shadow: 0 2px 8px rgba(0,0,0,0.4);
        }

        .arc-card {
            background: rgba(255,255,255,0.65);
            border: 1px solid rgba(26, 58, 92, 0.15);
            border-radius: 6px;
            padding: 16px 20px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        .arc-info {
            flex: 1;
        }

        .arc-info strong {
            font-size: 1rem;
            display: block;
            margin-bottom: 4px;
        }

        .arc-info p {
            font-size: 0.875rem;
            color: rgba(26, 58, 92, 0.65);
        }

        .arc-actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        button {
            background: transparent;
            color: #e06c6c;
            border: 1px solid rgba(224, 108, 108, 0.4);
            padding: 6px 14px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.85rem;
            transition: background 0.2s, border-color 0.2s;
        }

        button:hover {
            background: rgba(224, 108, 108, 0.15);
            border-color: #e06c6c;
        }

        a {
            color: #1a3a5c;
            text-decoration: none;
            font-size: 0.85rem;
            opacity: 0.7;
            transition: opacity 0.2s;
        }

        a:hover {
            opacity: 1;
        }

        .add-link {
            display: inline-block;
            margin-top: 20px;
            font-size: 0.9rem;
            opacity: 0.6;
        }

        .add-link:hover {
            opacity: 1;
        }

        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            font-size: 0.85rem;
            opacity: 0.5;
        }

        .back-link:hover {
            opacity: 1;
        }

        nav {
            display: flex;
            gap: 8px;
            margin-bottom: 28px;
        }

        nav a {
            padding: 7px 16px;
            border: 1px solid rgba(26, 58, 92, 0.2);
            border-radius: 5px;
            font-size: 0.82rem;
            opacity: 0.55;
            background: rgba(255,255,255,0.5);
        }

        nav a:hover {
            opacity: 1;
            background: rgba(26, 58, 92, 0.1);
            border-color: rgba(26, 58, 92, 0.45);
        }

        nav a.active {
            opacity: 1;
            border-color: rgba(26, 58, 92, 0.5);
            background: rgba(26, 58, 92, 0.08);
        }
    </style>
</head>
<body>
    <a href="/" class="back-link">← Home</a>
    <nav>
        <a href="/arcs" class="active">Arcs</a>
        <a href="/cards">Cards</a>
        <a href="/card-types">Card Types</a>
    </nav>
    <h1>One Piece Arcs</h1>
    <div>
        <% arcs.forEach(arc => { %>
            <div class="arc-card">
                <div class="arc-info">
                    <strong><%= arc.name %></strong>
                    <p><%= arc.description %></p>
                </div>
                <div class="arc-actions">
                    <a href="/arcs/<%= arc.id %>/edit">Edit</a>
                    <form action="/arcs/<%= arc.id %>/delete" method="POST" style="display:inline;">
                        <button type="submit">Delete</button>
                    </form>
                </div>
            </div>
        <% }) %>

        <a href="/arcs/new" class="add-link">+ Add new arc</a>
    </div>
</body>
</html>
