<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>One Piece Inventory</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #daeaf5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 40px 20px;
        }

        .logo {
            max-width: 280px;
            width: 100%;
            margin-bottom: 32px;
            filter: drop-shadow(0 4px 16px rgba(0,0,0,0.5));
        }

        h1 {
            color: #1a3a5c;
            font-size: 2rem;
            letter-spacing: 0.05em;
            margin-bottom: 36px;
            text-shadow: 0 2px 8px rgba(0,0,0,0.4);
        }

        nav {
            display: flex;
            flex-direction: column;
            gap: 12px;
            width: 100%;
            max-width: 260px;
        }

        a {
            display: block;
            color: #1a3a5c;
            text-decoration: none;
            font-size: 1rem;
            font-weight: 500;
            padding: 12px 24px;
            border: 1px solid rgba(245, 230, 200, 0.25);
            border-radius: 6px;
            background: rgba(255,255,255,0.5);
            letter-spacing: 0.04em;
            transition: background 0.2s, border-color 0.2s, transform 0.15s;
        }

        a:hover {
            background: rgba(245, 230, 200, 0.12);
            border-color: rgba(245, 230, 200, 0.6);
        }
    </style>
</head>
<body>
    <img class="logo" src="/One_Piece_Card_Game_Logo.webp" alt="One Piece Card Game Logo">
    <h1>One Piece Inventory</h1>
    <nav>
        <a href="/arcs">Arcs</a>
        <a href="/cards">Cards</a>
        <a href="/card-types">Card Types</a>
    </nav>
</body>
</html>
