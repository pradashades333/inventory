<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cards</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f0f0f0;
            padding: 20px;
        }

        h1 {
            color: #333;
        }

        .card-item {
            background-color: white;
            border: 1px solid #ccc;
            padding: 15px;
            margin-bottom: 15px;
            border-radius: 5px;
        }

        .card-item p {
            margin: 5px 0;
        }

        button {
            background-color: red;
            color: white;
            border: none;
            padding: 5px 10px;
            cursor: pointer;
        }

        a {
            color: blue;
            margin-left: 10px;
        }

        .add-link {
            display: block;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <h1>Cards</h1>
    <div>
        <% cards.forEach(card => { %>
            <div class="card-item">
                <p><strong><%= card.name %></strong></p>
                <p>Price: <%= card.price %></p>
                <p>Rarity: <%= card.rarity %></p>
                <p>Stock: <%= card.stock %></p>
                <form action="/cards/<%= card.id %>/delete" method="POST" style="display:inline;">
                    <button type="submit">Delete</button>
                </form>
                <a href="/cards/<%= card.id %>/edit">Edit</a>
            </div>
        <% }) %>

        <a href="/cards/new" class="add-link">+ Add new card</a>
    </div>
</body>
</html>