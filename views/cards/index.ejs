<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cards</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #daeaf5;
            min-height: 100vh;
            padding: 40px 20px;
            color: #1a3a5c;
        }

        h1 {
            font-size: 1.8rem;
            letter-spacing: 0.05em;
            margin-bottom: 28px;
            text-shadow: 0 2px 8px rgba(0,0,0,0.4);
        }

        .card-item {
            background: rgba(255,255,255,0.65);
            border: 1px solid rgba(26, 58, 92, 0.15);
            border-radius: 6px;
            padding: 14px 20px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
        }

        .card-meta {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .card-meta strong {
            font-size: 0.95rem;
        }

        .card-meta span {
            font-size: 0.78rem;
            opacity: 0.45;
            letter-spacing: 0.03em;
        }

        .actions {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-shrink: 0;
        }

        button {
            background: transparent;
            color: #e06c6c;
            border: 1px solid rgba(224, 108, 108, 0.4);
            padding: 6px 14px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 0.85rem;
            transition: background 0.2s, border-color 0.2s;
        }

        button:hover {
            background: rgba(224, 108, 108, 0.15);
            border-color: #e06c6c;
        }

        a {
            color: #1a3a5c;
            text-decoration: none;
            font-size: 0.85rem;
            opacity: 0.7;
            transition: opacity 0.2s;
        }

        a:hover {
            opacity: 1;
        }

        .add-link {
            display: inline-block;
            margin-top: 20px;
            opacity: 0.6;
        }

        .back-link {
            display: inline-block;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        nav {
            display: flex;
            gap: 8px;
            margin-bottom: 28px;
        }

        nav a {
            padding: 7px 16px;
            border: 1px solid rgba(26, 58, 92, 0.2);
            border-radius: 5px;
            font-size: 0.82rem;
            opacity: 0.55;
            background: rgba(255,255,255,0.5);
        }

        nav a:hover {
            opacity: 1;
            background: rgba(26, 58, 92, 0.1);
            border-color: rgba(26, 58, 92, 0.45);
        }

        nav a.active {
            opacity: 1;
            border-color: rgba(26, 58, 92, 0.5);
            background: rgba(26, 58, 92, 0.08);
        }
    </style>
</head>
<body>
    <a href="/" class="back-link">← Home</a>
    <nav>
        <a href="/arcs">Arcs</a>
        <a href="/cards" class="active">Cards</a>
        <a href="/card-types">Card Types</a>
    </nav>
    <h1>Cards</h1>
    <div>
        <% cards.forEach(card => { %>
            <div class="card-item">
                <div class="card-meta">
                    <strong><a href="/cards/<%= card.id %>"><%= card.name %></a></strong>
                    <span><%= card.rarity %> &middot; $<%= card.price %> &middot; Stock: <%= card.stock %></span>
                </div>
                <div class="actions">
                    <a href="/cards/<%= card.id %>/edit">Edit</a>
                    <form action="/cards/<%= card.id %>/delete" method="POST" style="display:inline;">
                        <button type="submit">Delete</button>
                    </form>
                </div>
            </div>
        <% }) %>

        <a href="/cards/new" class="add-link">+ Add new card</a>
    </div>
</body>
</html>
